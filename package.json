{
  "name": "temperpack",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "esbuild js/src/main.js --bundle --format=iife --outfile=js/dist/temperpack.js --minify && esbuild css/temperpack.css --minify --outfile=css/temperpack.min.css",
    "dev": "esbuild js/src/main.js --bundle --format=iife --outfile=js/dist/temperpack.js --watch"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "split-type": "^0.3.4"
  }
}
